# Supplementary git config — lives at ~/.config/git/config (XDG).
# Keeps personal identity (name, email, signing) in ~/.gitconfig untouched.

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true          # n/N to jump between diff sections
    line-numbers = true
    side-by-side = true
    features = catppuccin-dark   # updated by ~/.config/kitty/sync-theme on appearance change

[delta "catppuccin-dark"]
    syntax-theme = Catppuccin Macchiato

[delta "catppuccin-light"]
    syntax-theme = Catppuccin Latte
    light = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

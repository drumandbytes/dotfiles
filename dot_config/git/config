# Supplementary git config — lives at ~/.config/git/config (XDG).
# Keeps personal identity (name, email, signing) in ~/.gitconfig untouched.

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[include]
    path = catppuccin.gitconfig

[delta]
    navigate = true          # n/N to jump between diff sections
    line-numbers = true
    side-by-side = true
    features = catppuccin-macchiato   # updated by ~/.config/kitty/sync-theme on appearance change

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

#!/bin/zsh
if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" = "Dark" ]]; then
    kitty_target="$HOME/.config/kitty/themes/macchiato.conf"
else
    kitty_target="$HOME/.config/kitty/themes/latte.conf"
fi

# kitty: swap symlink and reload live instances
theme="$HOME/.config/kitty/theme.conf"
rm -f "$theme"
ln -s "$kitty_target" "$theme"
for pid in $(ps -x | grep '/Applications/kitty.app/Contents/MacOS/kitty' | grep -v grep | awk '{ print $1 }'); do
    kill -SIGUSR1 "$pid"
done


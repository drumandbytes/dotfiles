# === chezmoi Helpers ===
# Sync the chezmoi source dir to origin/main, then apply.
# Handles: detached HEAD, wrong branch, missing tracking, diverged local commits.
_chezmoi_sync() {
    local src
    src=$(chezmoi source-path 2>/dev/null) || { echo "❌ chezmoi source-path failed"; return 1; }

    echo "🔄 Fetching origin/main..."
    git -C "$src" fetch origin main || { echo "❌ fetch failed"; return 1; }

    # checkout -B resets the main branch to origin/main regardless of current state:
    # works from any branch, detached HEAD, or after a failed rebase.
    git -C "$src" checkout -B main origin/main

    chezmoi apply
}

# === Elite Maintenance Workflow ===
mnt() {
    echo "🚀 Starting Elite Maintenance..."

    # 0. Sync dotfiles first so everything below reflects latest config
    echo "📦 Syncing dotfiles..."
    _chezmoi_sync || echo "⚠️  chezmoi sync failed — continuing anyway"

    # 1. System Updates & Cleanup
    echo "🍺 Updating Homebrew..."
    brew update && brew upgrade --greedy && brew cleanup --prune=all
    mac-cleanup
{{ if .alt_tools -}}
    tldr --update
{{- end }}

    # 2. Sheldon Static Source
    echo "🛡️ Refreshing Sheldon plugins..."
    sheldon lock --update
    sheldon source > ~/.zsh/sheldon.zsh

    # 3. Static Initialization Caching
    echo "🏎️ Caching Tool Initializations..."
    bash <(chezmoi execute-template < "$(chezmoi source-path)/.chezmoiscripts/run_onchange_generate-tool-inits.sh.tmpl")

    # 4. Binary Compilation (Dynamic & Automatic)
    echo "🏗️  Rebuilding binaries from a clean slate..."
    rm -f ~/.zshrc.zwc ~/.zcompdump.zwc ~/.zsh/*.zwc ~/.zsh/completions/*.zwc
    builtin zcompile ~/.zshrc
    for f in ~/.zsh/*.zsh(N); do builtin zcompile "$f"; done
    for comp_file in ~/.zsh/completions/*(N-.); do builtin zcompile "$comp_file"; done
    [[ -f ~/.zcompdump ]] && builtin zcompile ~/.zcompdump

    # 5. Backup & Reload
    zsh-bak
    echo "✅ Optimization complete. Reloading..."
    exec zsh
}

{{ if .bitwarden -}}
# === Bitwarden Search (ID-Based Parsing) ===
bw-search() {
    if [[ -z "$BW_SESSION" ]]; then
        echo "🔐 No session. Run 'bw-vault --regen' first."
        return 1
    fi
    local item item_id choice
    item=$(bw-vault list items 2>/dev/null | jq -r '.[] | "\(.name) (\(.login.username)) [\(.id)]"' | fzf --header "Search Bitwarden" --height 40%)
    if [[ -n "$item" ]]; then
        item_id=$(echo "$item" | sed -n 's/.*\[\(.*\)\].*/\1/p')
        choice=$(echo "Password\nUsername" | fzf --height 10% --reverse)
        case "$choice" in
            Password) bw-vault get password "$item_id" | pbcopy && echo "✅ Password copied." ;;
            Username) bw-vault get item "$item_id" | jq -r '.login.username' | pbcopy && echo "✅ Username copied." ;;
        esac
    fi
}
{{- end }}

# === Sheldon Plugin Management ===
# Add a deferred sheldon plugin directly to the chezmoi source template and activate it.
sh-add() {
    local repo="${1:?Usage: sh-add <user/repo>}"
    local name="${repo##*/}"
    local src
    src="$(chezmoi source-path)/dot_config/sheldon/plugins.toml.tmpl"

    [[ -f "$src" ]] || { echo "❌ chezmoi source not found: $src"; return 1; }
    grep -qF "github = \"$repo\"" "$src" && { echo "⚠️  $repo already in plugins.toml"; return 0; }

    # Insert new plugin block before the "Syntax highlighting (must be last)" marker
    awk -v name="$name" -v repo="$repo" \
        '/^# Syntax highlighting \(must be last\)/ {
            print "[plugins." name "]"
            print "github = \"" repo "\""
            print "apply = [\"defer\"]"
            print ""
        }
        { print }' "$src" > "${src}.tmp" && mv "${src}.tmp" "$src" || rm -f "${src}.tmp"

    echo "✅ Added sheldon plugin: $repo"

    # Deploy rendered template, rebuild lock file, and hot-reload
    chezmoi apply ~/.config/sheldon/plugins.toml
    sheldon lock --update
    sheldon source > ~/.zsh/sheldon.zsh
    source ~/.zsh/sheldon.zsh
    echo "📝 Persisted and activated."
}

# === Brew Drift Detection ===
# Interactively promote untracked brew packages into the chezmoi-managed
# Brewfile template. Picks up brew leaves + casks not yet in ~/.Brewfile,
# lets you assign each to a template section via fzf, then inserts the line
# directly into the chezmoi source (dot_Brewfile.tmpl).
brewsync() {
    local src brewfile tmp
    src="$(chezmoi source-path)/dot_Brewfile.tmpl"
    brewfile="$HOME/.Brewfile"
    tmp="${src}.tmp"

    [[ -f "$src" ]]      || { echo "❌ Brewfile template not found: $src"; return 1 }
    [[ -f "$brewfile" ]] || { echo "❌ ~/.Brewfile not found — run: chezmoi apply ~/.Brewfile"; return 1 }

    # Collect untracked top-level formulae and casks.
    # Use the short name (strip tap prefix) for matching: brew leaves may return
    # "hashicorp/tap/vault" or just "vault"; brew list --cask always returns the
    # short form (e.g. "airbattery") even when the Brewfile has the tap-qualified
    # form (e.g. cask "lihaoyun6/tap/airbattery").  The regex ([^"'/]+/)* matches
    # zero or more leading tap path components so both forms are detected.
    local -a untracked=()
    while IFS= read -r pkg; do
        local short="${pkg##*/}"
        grep -qE "^brew [\"']([^\"'/]+/)*${short}[\"']" "$brewfile" || untracked+=("brew:::$pkg")
    done < <(brew leaves)
    while IFS= read -r cask; do
        local short="${cask##*/}"
        grep -qE "^cask [\"']([^\"'/]+/)*${short}[\"']" "$brewfile" || untracked+=("cask:::$cask")
    done < <(brew list --cask 2>/dev/null)

    (( ${#untracked[@]} == 0 )) && { echo "✅ All installed packages are tracked in ~/.Brewfile"; return 0 }
    echo "🍺 ${#untracked[@]} untracked package(s) — categorize each or skip:\n"

    # Maps section name → unique header string used as awk anchor.
    # Conditional sections appear twice in the file (taps block + main block);
    # anchoring on the section header comment targets the main block only.
    local -A section_anchors=(
        [alt_tools]="Alt-tools"
        [bitwarden]="Bitwarden"
        [docker]="Docker"
        [kubernetes]="Kubernetes"
        [java]="Java"
        [macos_utils]="macOS utilities"
        [macos_cosmetic]="macOS cosmetic"
        [macos_media]="Media"
        [dev_apps]="Dev apps"
        [touchbar]="TouchBar"
    )
    local -a categories=(base alt_tools bitwarden docker kubernetes java \
                         macos_utils macos_cosmetic macos_media dev_apps touchbar skip)
    local added=0

    for entry in "${untracked[@]}"; do
        local type="${entry%%:::*}" name="${entry##*:::}"

        local chosen
        chosen=$(printf '%s\n' "${categories[@]}" | \
            fzf --height 15 --layout=reverse --border --no-sort \
                --prompt="  Section > " \
                --header="  ➕  $type \"$name\"")
        [[ -z "$chosen" || "$chosen" == "skip" ]] && { echo "  ⏭  Skipped: $name"; continue }

        local new_line="$type \"$name\""

        if [[ "$chosen" == "base" ]]; then
            # 2-line lookahead buffer: when we see "# Alt-tools", prev1 = "# ==="
            # and prev2 = the blank line before it.  Emit: blank → new_line → # === → # Alt-tools
            awk -v nl="$new_line" '
                BEGIN { p2=""; p1=""; n=0 }
                /^# Alt-tools/ {
                    if (n >= 2) print p2
                    print nl
                    print p1
                    print
                    p2=""; p1=""; n=0; next
                }
                { if (n >= 2) print p2; p2=p1; p1=$0; n++ }
                END { if (n >= 2) print p2; if (n >= 1) print p1 }
            ' "$src" > "$tmp" && mv "$tmp" "$src"
        else
            # Insert new_line before the end-block that closes this section.
            local anchor="${section_anchors[$chosen]}"
            awk -v anchor="$anchor" -v nl="$new_line" '
                $0 ~ anchor { in_sec=1 }
                in_sec && /^\{\{ end/ { print nl; in_sec=0 }
                { print }
            ' "$src" > "$tmp" && mv "$tmp" "$src"
        fi

        echo "  ✅  [$chosen] $new_line"
        (( added++ ))
    done

    rm -f "$tmp"

    if (( added > 0 )); then
        echo "\n📝 Updated: $(basename "$src")"
        echo "   Deploy : chezmoi apply ~/.Brewfile"
        echo "   Commit : chezmoi cd && git add -p && git commit"
    fi
}

# === Interactive Tools (FZF) ===
{{ if .alt_tools -}}
help-cmd() {
    local FZF_DEFAULT_OPTS=""
    local cmd
    cmd=$( {
        alias | sed 's/^/alias: /'
        command rg '^[[:space:]]*[a-zA-Z0-9_-]+\(\)' ~/.zsh/functions.zsh | sed -E 's/^[[:space:]]*([a-zA-Z0-9_-]+).*/func:  \1/'
    } | fzf --height 40% --layout=reverse --border --ansi --header 'Search Personal Aliases & Functions' )
    if [[ -n "$cmd" ]]; then
        local final_cmd=$(echo "$cmd" | sed -E 's/^(alias|func):[[:space:]]+//' | cut -d'=' -f1)
        eval "$final_cmd"
    fi
}
{{- end }}

fkill() {
    local pid
    pid=$(ps -ef | sed 1d | fzf -m --ansi --layout=reverse --header 'Select process to kill' | awk '{print $2}')
    [[ -n "$pid" ]] && echo "$pid" | xargs kill "-${1:-9}"
}

fgb() {
    local branches branch
    branches=$(git branch --all | grep -v HEAD) &&
    branch=$(echo "$branches" | fzf-tmux -d $(( 2 + $(echo "$branches" | wc -l) )) +m \
             --preview 'git log --oneline --graph --date=short --color=always' ) &&
    git checkout $(echo "$branch" | sed "s/.* //" | sed "s#remotes/[^/]*/##")
}

zsh-bak() {
    local bak_dir="$HOME/Backups/zsh"
    local marker="$bak_dir/.last_backup_check"
    mkdir -p "$bak_dir"
    local changes=$(command find ~/.zshrc ~/.zsh ~/.config/kitty ~/.config/sheldon/plugins.toml ~/.config/git -newer "$marker" 2>/dev/null)
    if [[ -n "$changes" || ! -f "$marker" ]]; then
        local bak_name="zsh_bak_$(date +%Y%m%d_%H%M%S).zip"
        zip -rq "$bak_dir/$bak_name" ~/.zshrc ~/.zsh ~/.config/kitty ~/.config/sheldon/plugins.toml ~/.config/git -x "*.zwc"
        touch "$marker"
        echo "📦 Backup created: $bak_name"
    fi
}

# === Completion Management ===
# Detect a tool's completion syntax, generate the file, and persist it to the
# chezmoi run_onchange_ script so future installs get it automatically.
comp-add() {
    local tool="${1:?Usage: comp-add <toolname>}"
    local outfile="$HOME/.zsh/completions/_${tool}"
    local script
    script="$(chezmoi source-path)/.chezmoiscripts/run_onchange_generate-tool-inits.sh.tmpl"

    # Try common completion syntax patterns in order of prevalence
    local cmd="" try
    local -a tries=(
        "$tool completion zsh"
        "$tool completion -s zsh"
        "$tool completion --shell zsh"
        "$tool completions zsh"
        "$tool generate-shell-completion zsh"
    )
    for try in "${tries[@]}"; do
        if eval "$try" > "$outfile" 2>/dev/null && [[ -s "$outfile" ]]; then
            cmd="$try"
            break
        fi
    done

    if [[ -z "$cmd" ]]; then
        rm -f "$outfile"
        echo "❌ Could not auto-detect completion syntax for '${tool}'."
        echo "   Try manually: <tool> completion zsh > ~/.zsh/completions/_${tool}"
        return 1
    fi

    builtin zcompile "$outfile" 2>/dev/null
    echo "✅ Generated ~/.zsh/completions/_${tool}  (via: ${cmd})"

    # Persist to chezmoi source script (insert before marker)
    if [[ -f "$script" ]] && ! grep -qF "_${tool}" "$script"; then
        awk -v line="cmd ${tool} && ${cmd} > ~/.zsh/completions/_${tool}" \
            '/^# --- end completions ---/{print line} 1' \
            "$script" > "${script}.tmp" && mv "${script}.tmp" "$script" && chmod +x "$script" || rm -f "${script}.tmp"

        echo "📝 Persisted to $(basename "$script")"
    fi
}

# === uv Tool Management ===
# Install a global uv tool and persist it to the chezmoi run_onchange_ script
# so future installs get it automatically.
# Usage: uv-add <package>             e.g. uv-add httpie
#        uv-add "<package>[extra,...]" e.g. uv-add "python-lsp-server[pylsp-mypy]"
uv-add() {
    local pkg="${1:?Usage: uv-add <package>}"
    local script
    script="$(chezmoi source-path)/.chezmoiscripts/run_onchange_uv-tools.sh"

    uv tool install "$pkg" || return 1
    echo "✅ Installed uv tool: ${pkg}"

    if [[ -f "$script" ]] && ! grep -qF "\"${pkg}\"" "$script"; then
        awk -v line="uv tool install \"${pkg}\"" \
            '/^# --- end uv tools ---/{print line} 1' \
            "$script" > "${script}.tmp" && mv "${script}.tmp" "$script" || rm -f "${script}.tmp"

        echo "📝 Persisted to $(basename "$script")"
    fi
}

# === Lazy-loaded tools (fallback when generated inits don't exist yet) ===
# Deferred inits override these on startup when the generated files are present.
z()        { unfunction z zi; eval "$(zoxide init zsh)"; z "$@" }
zi()       { z; zi "$@" }
carapace() { unfunction carapace; eval "$(carapace _carapace zsh)"; carapace "$@" }
mise()     { unfunction mise; eval "$(mise activate zsh)"; mise "$@" }
{{ if .kubernetes }}
# === gcloud (lazy-loaded — SDK is large) ===
gcloud() {
    unfunction gcloud gsutil bq
    [[ -f '/opt/homebrew/share/google-cloud-sdk/path.zsh.inc' ]] && . '/opt/homebrew/share/google-cloud-sdk/path.zsh.inc'
    [[ -f '/opt/homebrew/share/google-cloud-sdk/completion.zsh.inc' ]] && . '/opt/homebrew/share/google-cloud-sdk/completion.zsh.inc'
    gcloud "$@"
}
gsutil() { gcloud; gsutil "$@" }
bq()     { gcloud; bq "$@" }
{{ end }}

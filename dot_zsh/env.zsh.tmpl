# Homebrew & Editor
export HOMEBREW_NO_ENV_HINTS=true
export EDITOR="fresh"
export ZSH_AUTOSUGGEST_MANUAL_REBIND=1
export CARAPACE_LENIENT=1

# fzf configuration
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git --exclude node_modules --exclude .DS_Store'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]]; then
    export COLORFGBG="15;0"
    _fzf_colors="--color=bg+:#363a4f,bg:#24273a,spinner:#f4dbd6,hl:#ed8796
      --color=fg:#cad3f5,header:#ed8796,info:#c6a0f6,pointer:#f4dbd6
      --color=marker:#b7bdf8,fg+:#cad3f5,prompt:#c6a0f6,hl+:#ed8796
      --color=selected-bg:#494d64,border:#363a4f,label:#cad3f5"
else
    export COLORFGBG="0;15"
    _fzf_colors="--color=bg+:#ccd0da,bg:#eff1f5,spinner:#dc8a78,hl:#d20f39
      --color=fg:#4c4f69,header:#d20f39,info:#8839ef,pointer:#dc8a78
      --color=marker:#7287fd,fg+:#4c4f69,prompt:#8839ef,hl+:#d20f39
      --color=selected-bg:#bcc0cc,border:#ccd0da,label:#4c4f69"
fi
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border
  --preview 'COLORFGBG="$(launchctl getenv COLORFGBG 2>/dev/null)" bat --color=always --style=numbers --line-range :500 {}'
  ${_fzf_colors}"
unset _fzf_colors
# Note: CTRL+R is handled by atuin (not fzf)

# Paths
# Note: java, node, ruby, uv runtimes are managed by mise — no manual PATH entries needed.
export PATH="$HOME/.local/bin:${KREW_ROOT:-$HOME/.krew}/bin:$HOME/.lmstudio/bin:$PATH"
{{ if .java -}}
# libpq psql client (Homebrew-linked)
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"
{{ end -}}

# Fpath (Completions)
fpath=(~/.zsh/completions $HOME/.docker/completions /opt/homebrew/share/zsh/site-functions $fpath)

# App specific
{{- if .bitwarden }}
export BW_USER="{{ .bw_email }}"
{{- end }}
export LESSHSTFILE="${XDG_CACHE_HOME:-$HOME/.cache}/lesshst"
export DOCKER_DEFAULT_PLATFORM=linux/amd64

brew "shfmt"
brew "sl"
brew "starship"
brew "tldr"
brew "wget2"
brew "xh"
brew "zoxide"
brew "sinelaw/fresh/fresh"

# --- Bitwarden ---
{{ if .bitwarden -}}
brew "bitwarden-cli"
cask "bitwarden"
{{ end -}}

# --- Docker + Colima ---
{{ if .docker -}}
brew "colima", restart_service: :changed
brew "docker"
brew "docker-buildx"
brew "docker-compose"
{{ end -}}

# --- Kubernetes ---
{{ if .kubernetes -}}
brew "kubernetes-cli"
brew "kubectx"
brew "k9s"
brew "mintoolkit"
brew "hashicorp/tap/vault"
cask "gcloud-cli"
{{ end -}}

# --- Java (runtime managed via mise, libpq for psql client) ---
{{ if .java -}}
brew "libpq", link: true
{{ end -}}


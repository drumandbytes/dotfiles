{{- if .bitwarden -}}
#!/usr/bin/env zsh
# bw-vault — thin Bitwarden CLI wrapper with session caching.
# Session key is cached in $XDG_CACHE_HOME/bitwarden.session (chmod 600)
# so subsequent calls reuse it without re-prompting.
#
# Usage:
#   bw-vault <bw subcommand + args>   — runs bw with a valid session
#   bw-vault --regen                  — force re-login and refresh session
#   bw-vault login|logout|config ...  — pass through directly (no session needed)

bw_exec=$(command -v bw)
bw_session_file="${XDG_CACHE_HOME:-$HOME/.cache}/bitwarden.session"

_bw_regen() {
    $bw_exec logout 2>/dev/null
    local raw_key
    raw_key=$($bw_exec login "{{ .bw_email }}" --raw)
    if [[ -n "$raw_key" ]]; then
        mkdir -p "$(dirname "$bw_session_file")"
        echo "$raw_key" > "$bw_session_file"
        chmod 600 "$bw_session_file"
        echo "$raw_key"
    fi
}

if [[ -z "$BW_SESSION" ]]; then
    if [[ -s "$bw_session_file" ]]; then
        BW_SESSION=$(cat "$bw_session_file")
    fi
fi

case "$1" in
    --regen) _bw_regen ;;
    login|logout|config) $bw_exec "$@" ;;
    *)
        [[ -z "$BW_SESSION" ]] && BW_SESSION=$(_bw_regen)
        local output
        output=$($bw_exec "$@" --session "$BW_SESSION" 2>&1)
        if echo "$output" | grep -q "Session key is invalid\|not logged in\|Vault is locked"; then
            BW_SESSION=$(_bw_regen)
            $bw_exec "$@" --session "$BW_SESSION"
        else
            echo "$output"
        fi
        ;;
esac
{{- end }}
